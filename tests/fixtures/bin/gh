#!/bin/sh
# Fake gh binary for tests.
# Behavior is controlled via environment variables:
#   FAKE_GH_PR_VIEW_JSON  — JSON to print for `gh pr view` (default: OPEN/MERGEABLE)
#   FAKE_GH_PR_MERGE_EXIT — exit code for `gh pr merge` (default: 0)
#   FAKE_GH_PR_VIEW_EXIT  — exit code for `gh pr view` (default: 0)

case "$*" in
  *"pr view"*)
    if [ "${FAKE_GH_PR_VIEW_EXIT:-0}" != "0" ]; then
      echo "gh pr view error" >&2
      exit "${FAKE_GH_PR_VIEW_EXIT}"
    fi
    echo "${FAKE_GH_PR_VIEW_JSON:-{\"state\":\"OPEN\",\"mergeable\":\"MERGEABLE\",\"headRefOid\":\"abc123\",\"number\":1}}"
    ;;
  *"pr merge"*)
    exit "${FAKE_GH_PR_MERGE_EXIT:-0}"
    ;;
  *"pr list"*)
    echo "${FAKE_GH_PR_LIST_JSON:-[]}"
    ;;
  *)
    echo "fake-gh: unknown command: $*" >&2
    exit 1
    ;;
esac
